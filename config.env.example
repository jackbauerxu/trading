# Copy to config.env and fill the secrets you want this combo runner to use.
# Existing shell environment variables win over values in this file.

# Absolute paths to the already installed components.
TRADINGAGENTS_DIR=/Users/g90/Documents/Codex/2026-06-10/export-openai-api-key-openai-gpt/TradingAgents
TRADINGAGENTS_PYTHON=/Users/g90/Documents/Codex/2026-06-10/export-openai-api-key-openai-gpt/TradingAgents/.venv/bin/python
UZI_SKILL_DIR=/Users/g90/Documents/Codex/2026-06-10/bash-git-clone-https-github-com/UZI-Skill
DAILY_STOCK_ANALYSIS_DIR=/Users/g90/Documents/Codex/2026-06-11/zhulinsen-daily-stock-analysis-https-github/work/daily_stock_analysis
PYTHON_BIN=/Users/g90/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3

# Unified stock universe. DSA accepts A/HK/US forms such as 600519,hk00700,AAPL.
# TradingAgents uses Yahoo-style suffixes for non-US tickers, for example 600519.SS.
STOCK_LIST=NVDA
TRADINGAGENTS_TICKERS=NVDA
UZI_TICKERS=NVDA

# LLM config shared across projects.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
LITELLM_MODEL=openai/gpt-5.5
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese

# Telegram notification for DSA and combo-runner status messages.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
NOTIFICATION_REPORT_CHANNELS=telegram

# Optional UZI data-source boost.
MX_APIKEY=
TUSHARE_TOKEN=
UZI_DEPTH=lite

# Optional market data fallback chain.
GLOBAL_STOCK_DATA_ENABLED=1
GLOBAL_STOCK_DATA_FIRST=1
STOCK_API_ENABLED=1
STOCK_API_COMMAND=npx
STOCK_API_TIMEOUT=18
ALPHA_VANTAGE_API_KEY=
TICKDB_API_KEY=
TICKDB_API_BASE=https://api.tickdb.ai
KRONOS_ENABLED=0
KRONOS_DIR=/opt/ai-stock-combo/work/repos/Kronos
KRONOS_PYTHON=/opt/ai-stock-combo/.kronos-venv/bin/python
KRONOS_MODEL=/opt/ai-stock-combo/work/models/Kronos-small
KRONOS_TOKENIZER=/opt/ai-stock-combo/work/models/Kronos-Tokenizer-base
KRONOS_DEVICE=cpu
KRONOS_PRED_LEN=5
KRONOS_MIN_LOOKBACK=40
KRONOS_LOOKBACK=90
KRONOS_SYMBOL_LIMIT=120
KRONOS_TIMEOUT=900

# Optional Dexter US-stock auxiliary research layer.
DEXTER_ENABLED=0
DEXTER_DIR=/opt/ai-stock-combo/work/repos/dexter
DEXTER_COMMAND=bun
DEXTER_MODEL=gpt-5.5
DEXTER_TOP_N=10
DEXTER_TIMEOUT=900
DEXTER_MAX_ITERATIONS=4
DEXTER_TOOL_ALLOWLIST=get_financials,get_market_data,read_filings,web_search
DEXTER_REQUIRE_FINANCIAL_DATASETS=1
DEXTER_BUY_GATE=1

# Optional Vibe-Trading post-Top10 review layer.
VIBE_TRADING_ENABLED=0
VIBE_TRADING_DIR=/opt/ai-stock-combo/work/repos/Vibe-Trading
VIBE_TRADING_COMMAND=/opt/ai-stock-combo/.vibe-trading-venv/bin/vibe-trading
VIBE_TRADING_PROVIDER=openai
VIBE_TRADING_MODEL=gpt-4o-mini
VIBE_TRADING_TOP_N=5
VIBE_TRADING_WORKERS=2
VIBE_TRADING_TIMEOUT_PER_SYMBOL=420
VIBE_TRADING_TIMEOUT=1200
VIBE_TRADING_TOOL_TIMEOUT=180
